<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:LDOCE5ViewerX.Services"
        xmlns:vm="using:LDOCE5ViewerX.ViewModels"
        x:Class="LDOCE5ViewerX.Views.SettingsDialog"
        x:DataType="vm:SettingsDialogViewModel"
        Width="600"
        Height="560"
        MinWidth="440"
        MinHeight="480"
        Icon="/Assets/LDOCE5ViewerX.ico"
        FontFamily="{Binding Config.ApplicationFontFamily}"
        Background="{DynamicResource DialogWindowBackgroundBrush}"
        Title="Settings">

    <Window.Styles>

        <Style Selector="TextBlock.settingLabel">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.settingValue">
            <Setter Property="Width" Value="56"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="35"/>
        </Style>

    </Window.Styles>

    <Grid RowDefinitions="*,Auto"
          Margin="14,4,14,14"
          RowSpacing="12">
        <TabControl>
            <TabItem Header="Appearance">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12"
                                Margin="0,10,12,0">
                        <Grid ColumnDefinitions="130,*"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="8">
                            <TextBlock Grid.Row="0"
                                       Classes="settingLabel"
                                       Text="Theme"/>
                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="12">
                                <RadioButton GroupName="SettingsThemeMode"
                                             Content="Automatic"
                                             IsChecked="{Binding Config.IsAutomaticThemeModeSelected, Mode=TwoWay}"/>
                                <RadioButton GroupName="SettingsThemeMode"
                                             Content="Light"
                                             IsChecked="{Binding Config.IsLightThemeModeSelected, Mode=TwoWay}"/>
                                <RadioButton GroupName="SettingsThemeMode"
                                             Content="Dark"
                                             IsChecked="{Binding Config.IsDarkThemeModeSelected, Mode=TwoWay}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Classes="settingLabel"
                                       Text="Font family"/>
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     PlaceholderText="Inter"
                                     Text="{Binding Config.CustomFontFamilyName, Mode=TwoWay}"/>
                        </Grid>

                        <Grid ColumnDefinitions="130,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="8">
                            <TextBlock Grid.Row="0"
                                       Classes="settingLabel"
                                       Text="Search list font"/>
                            <Grid Grid.Row="0"
                                  Grid.Column="1"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Slider Minimum="{x:Static services:AppConfiguration.MinimumSearchListBaseFontSize}"
                                        Maximum="{x:Static services:AppConfiguration.MaximumSearchListBaseFontSize}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Config.SearchListBaseFontSize, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="1"
                                           Classes="settingValue"
                                           Text="{Binding Config.SearchListBaseFontSize, StringFormat='{}{0:0} pt'}"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ResetSearchListBaseFontSizeCommand}"
                                        Content="Reset"/>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Classes="settingLabel"
                                       Text="Content font"/>
                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Slider Minimum="{x:Static services:AppConfiguration.MinimumContentBaseFontSize}"
                                        Maximum="{x:Static services:AppConfiguration.MaximumContentBaseFontSize}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Config.ContentBaseFontSize, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="1"
                                           Classes="settingValue"
                                           Text="{Binding Config.ContentBaseFontSize, StringFormat='{}{0:0} pt'}"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ResetContentBaseFontSizeCommand}"
                                        Content="Reset"/>
                            </Grid>

                            <TextBlock Grid.Row="2"
                                       Classes="settingLabel"
                                       Text="Content zoom"/>
                            <Grid Grid.Row="2"
                                  Grid.Column="1"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Slider Minimum="{x:Static services:AppConfiguration.MinimumZoomPower}"
                                        Maximum="{x:Static services:AppConfiguration.MaximumZoomPower}"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Config.ZoomPower, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="1"
                                           Classes="settingValue"
                                           Text="{Binding Config.ZoomPercentageText}"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ResetZoomCommand}"
                                        Content="Reset"/>
                            </Grid>

                            <TextBlock Grid.Row="3"
                                       Classes="settingLabel"
                                       Text="Example italics"/>
                            <CheckBox Grid.Row="3"
                                      Grid.Column="1"
                                      IsChecked="{Binding Config.IsExampleItalicEnabled, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="4"
                                       Classes="settingLabel"
                                       Text="Example font"/>
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     PlaceholderText="Default"
                                     Text="{Binding Config.ExampleFontFamilyName, Mode=TwoWay}"/>
                        </Grid>

                        <Grid ColumnDefinitions="130,*"
                              RowDefinitions="Auto"
                              RowSpacing="8">
                            <TextBlock Classes="settingLabel"
                                       Text="Search list width"/>
                            <Grid Grid.Column="1"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Slider Minimum="{x:Static services:AppConfiguration.MinimumSearchListWidth}"
                                        Maximum="{x:Static services:AppConfiguration.MaximumSearchListWidth}"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Config.SearchListWidth, Mode=TwoWay}"/>
                                <TextBlock Grid.Column="1"
                                           Classes="settingValue"
                                           Text="{Binding Config.SearchListWidth, StringFormat='{}{0:0} px'}"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ResetSearchListWidthCommand}"
                                        Content="Reset"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Web">
                <Grid RowDefinitions="Auto,*,Auto"
                      Margin="0,10,12,0"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="130,*"
                          RowDefinitions="Auto"
                          RowSpacing="8">
                        <TextBlock Classes="settingLabel"
                                   Text="AssetBox links"/>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12">
                            <RadioButton GroupName="WebSearchAssetBoxMode"
                                         Content="Nouns only"
                                         IsChecked="{Binding Config.IsWebSearchAssetBoxNounEntriesOnlySelected, Mode=TwoWay}"/>
                            <RadioButton GroupName="WebSearchAssetBoxMode"
                                         Content="All entries"
                                         IsChecked="{Binding Config.IsWebSearchAssetBoxAllEntriesSelected, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Config.WebSearchSites}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="services:WebSearchSite">
                                <Border Padding="8"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                                    <Grid RowDefinitions="Auto,Auto"
                                          ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                          RowSpacing="6"
                                          ColumnSpacing="8">
                                        <CheckBox VerticalAlignment="Center"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                                        <TextBox Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 PlaceholderText="Title"
                                                 Text="{Binding Title, Mode=TwoWay}"/>
                                        <Button Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Content="Up"
                                                Click="OnMoveWebSearchSiteUpClicked"/>
                                        <Button Grid.Column="3"
                                                VerticalAlignment="Center"
                                                Content="Down"
                                                Click="OnMoveWebSearchSiteDownClicked"/>
                                        <Button Grid.Column="4"
                                                VerticalAlignment="Center"
                                                Content="Remove"
                                                Click="OnRemoveWebSearchSiteClicked"/>
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="4"
                                                 VerticalAlignment="Center"
                                                 PlaceholderText="https://example.com/search?q={query}"
                                                 Text="{Binding UrlTemplate, Mode=TwoWay}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="8">
                        <Button Command="{Binding AddWebSearchSiteCommand}"
                                Content="Add"/>
                        <Button Command="{Binding RestoreDefaultWebSearchSitesCommand}"
                                Content="Defaults"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Audio">
                <StackPanel Margin="0,10,12,0"
                            Spacing="8">
                    <Grid ColumnDefinitions="130,*,Auto">
                        <TextBlock Classes="settingLabel"
                                   Text="Volume"/>
                        <Slider Grid.Column="1"
                                Minimum="{x:Static services:AppConfiguration.MinimumAudioPlaybackVolume}"
                                Maximum="{x:Static services:AppConfiguration.MaximumAudioPlaybackVolume}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding Config.AudioPlaybackVolume, Mode=TwoWay}"/>
                        <TextBlock Grid.Column="2"
                                   Classes="settingValue"
                                   Text="{Binding Config.AudioPlaybackVolume, StringFormat='{}{0:0}%'}"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Clipboard">
                <StackPanel Margin="0,10,12,0"
                            Spacing="12">
                    <CheckBox Content="Monitor clipboard"
                              IsChecked="{Binding Config.IsClipboardMonitoringEnabled, Mode=TwoWay}"/>

                    <CheckBox Content="Use full index for clipboard search"
                              IsChecked="{Binding Config.IsFullIndexClipboardSearchEnabled, Mode=TwoWay}"/>

                    <Grid ColumnDefinitions="180,*,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          RowSpacing="8"
                          ColumnSpacing="8">
                        <TextBlock Grid.Row="0"
                                   Classes="settingLabel"
                                   Text="Active poll interval"/>
                        <NumericUpDown Grid.Row="0"
                                       Grid.Column="1"
                                       Minimum="50"
                                       Maximum="5000"
                                       Increment="50"
                                       Value="{Binding Config.ClipboardActiveMonitorIntervalMilliseconds, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Classes="settingLabel"
                                   Text="ms"/>

                        <TextBlock Grid.Row="1"
                                   Classes="settingLabel"
                                   Text="Idle poll interval"/>
                        <NumericUpDown Grid.Row="1"
                                       Grid.Column="1"
                                       Minimum="100"
                                       Maximum="60000"
                                       Increment="100"
                                       Value="{Binding Config.ClipboardIdleMonitorIntervalMilliseconds, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Classes="settingLabel"
                                   Text="ms"/>

                        <TextBlock Grid.Row="2"
                                   Classes="settingLabel"
                                   Text="Idle threshold"/>
                        <NumericUpDown Grid.Row="2"
                                       Grid.Column="1"
                                       Minimum="1"
                                       Maximum="3600"
                                       Increment="1"
                                       Value="{Binding Config.ClipboardIdleThresholdSeconds, Mode=TwoWay}"/>
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Classes="settingLabel"
                                   Text="sec"/>
                    </Grid>

                    <Button HorizontalAlignment="Right"
                            Command="{Binding ResetClipboardTimerCommand}"
                            Content="Reset timers"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto">
            <Button Grid.Column="1"
                    Command="{Binding CloseCommand}"
                    Content="Close"/>
        </Grid>
    </Grid>
</Window>
