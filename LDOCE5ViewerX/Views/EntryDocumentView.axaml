<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LDOCE5ViewerX.Views.EntryDocumentView">
    <ScrollViewer x:Name="DocumentScroller"
                  BringIntoViewOnFocusChange="False"
                  HorizontalScrollBarVisibility="Disabled">
        <LayoutTransformControl x:Name="ZoomTransformHost" Margin="20 20 28 20">
            <StackPanel x:Name="DocumentPanel" Spacing="8"/>
        </LayoutTransformControl>
    </ScrollViewer>
</UserControl>
